@page "/settings"
@attribute [Authorize]

@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS

<div class="space-y-6">
    <h1 class="text-lg font-semibold text-gray-100">Settings</h1>

    <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 space-y-5">
        <h2 class="text-sm font-medium text-gray-300">Data export &amp; import</h2>

        <div class="space-y-1">
            <p class="text-xs text-gray-500">Export all your tasks and capacity overrides as a JSON file.</p>
            <button class="bg-indigo-600 hover:bg-indigo-500 disabled:opacity-50 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors"
                    @onclick="Export" disabled="@_exporting">
                @(_exporting ? "Exporting..." : "Export data")
            </button>
        </div>

        <div class="border-t border-gray-800 pt-5 space-y-1">
            <p class="text-xs text-gray-500">Import a previously exported file. Existing tasks are updated in place; new tasks are added.</p>
            <label class="cursor-pointer inline-block @(_importing ? "opacity-50 pointer-events-none" : "") bg-gray-800 hover:bg-gray-700 text-gray-300 text-sm font-medium px-4 py-2 rounded-lg transition-colors">
                @(_importing ? "Importing..." : "Import data")
                <InputFile OnChange="Import" accept=".json" class="hidden" />
            </label>
            @if (_importError is not null)
            {
                <p class="text-xs text-red-400 mt-2">@_importError</p>
            }
            @if (_importSuccess)
            {
                <p class="text-xs text-green-400 mt-2">Import complete.</p>
            }
        </div>
    </div>
</div>

@code {
    private bool _exporting;
    private bool _importing;
    private string? _importError;
    private bool _importSuccess;

    private async Task Export()
    {
        _exporting = true;
        try
        {
            var client = HttpClientFactory.CreateClient("WebAPI");
            var json = await client.GetStringAsync("api/data/export");
            var filename = $"nudge-export-{DateTime.Now:yyyy-MM-dd}.json";
            await JS.InvokeVoidAsync("downloadFile", filename, json);
        }
        finally
        {
            _exporting = false;
        }
    }

    private async Task Import(InputFileChangeEventArgs e)
    {
        _importError = null;
        _importSuccess = false;
        _importing = true;
        try
        {
            using var stream = e.File.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            using var reader = new StreamReader(stream);
            var json = await reader.ReadToEndAsync();

            var client = HttpClientFactory.CreateClient("WebAPI");
            var content = new StringContent(json, System.Text.Encoding.UTF8, "application/json");
            var response = await client.PostAsync("api/data/import", content);

            if (response.IsSuccessStatusCode)
                _importSuccess = true;
            else
                _importError = await response.Content.ReadAsStringAsync();
        }
        catch (Exception ex)
        {
            _importError = $"Failed to read file: {ex.Message}";
        }
        finally
        {
            _importing = false;
        }
    }
}
