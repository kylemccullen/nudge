@page "/register"
@attribute [AllowAnonymous]
@layout AuthLayout

@using Nudge.Shared.DTOs
@using Nudge.Client.Services

@inject AuthService AuthService
@inject NavigationManager Navigation

<div class="min-h-screen bg-gray-950 flex items-center justify-center px-4">
    <div class="w-full max-w-sm">
        <div class="flex items-center gap-2 justify-center mb-8">
            <img src="icon.svg" class="h-6 w-6" alt="nudge icon" />
            <div class="text-xl font-semibold text-gray-100">nudge</div>
        </div>

        <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
            <h1 class="text-lg font-semibold text-gray-100 mb-6">Create account</h1>

            @if (_error is not null)
            {
                <p class="text-sm text-red-400 mb-4">@_error</p>
            }

            <EditForm Model="_model" OnValidSubmit="HandleRegister">
                <DataAnnotationsValidator />
                <div class="mb-4">
                    <label class="block text-sm text-gray-400 mb-1">Email</label>
                    <InputText @bind-Value="_model.Email" type="email"
                               class="w-full bg-gray-800 text-gray-100 border border-gray-700 rounded-lg px-3 py-2 text-base md:text-sm focus:outline-none focus:border-indigo-500"
                               placeholder="you@example.com" />
                </div>
                <div class="mb-4">
                    <label class="block text-sm text-gray-400 mb-1">Password</label>
                    <InputText @bind-Value="_model.Password" type="password"
                               class="w-full bg-gray-800 text-gray-100 border border-gray-700 rounded-lg px-3 py-2 text-base md:text-sm focus:outline-none focus:border-indigo-500"
                               placeholder="••••••••" />
                </div>
                <div class="mb-6">
                    <label class="block text-sm text-gray-400 mb-1">Invite code <span class="text-gray-600">(required for new accounts)</span></label>
                    <InputText @bind-Value="_model.InviteCode"
                               class="w-full bg-gray-800 text-gray-100 border border-gray-700 rounded-lg px-3 py-2 text-base md:text-sm focus:outline-none focus:border-indigo-500"
                               placeholder="Enter invite code" />
                </div>
                <button type="submit" disabled="@_loading"
                        class="w-full bg-indigo-600 hover:bg-indigo-500 disabled:opacity-50 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors">
                    @(_loading ? "Creating account..." : "Create account")
                </button>
            </EditForm>

            <p class="text-sm text-gray-500 text-center mt-4">
                Already have an account?
                <a href="/login" class="text-indigo-400 hover:text-indigo-300">Sign in</a>
            </p>
        </div>
    </div>
</div>

@code {
    private RegisterFormModel _model = new();
    private string? _error;
    private bool _loading;

    private async Task HandleRegister()
    {
        _loading = true;
        _error = null;

        var (success, error) = await AuthService.RegisterAsync(new RegisterRequest(_model.Email, _model.Password, _model.InviteCode));

        if (success)
            Navigation.NavigateTo("/login");
        else
            _error = error;

        _loading = false;
    }

    private class RegisterFormModel
    {
        public string Email { get; set; } = "";
        public string Password { get; set; } = "";
        public string? InviteCode { get; set; }
    }
}
