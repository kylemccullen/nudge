@using Nudge.Client.Enums
@using Nudge.Shared.DTOs
@using Nudge.Shared.Enums
@using Nudge.Shared.Extensions

@inject IHttpClientFactory ClientFactory

<li @key="Task.Id" data-task-id="@Task.Id" class="@ItemClass @(Task.Id == HighlightTaskId ? "task-highlight" : "") @(showContextMenu ? "z-50" : "")">
    <div class="flex items-center gap-2 w-full sm:flex-1 sm:w-auto min-w-0">
        @if (ShowCheckbox)
        {
            <input type="checkbox"
                   checked="@Task.IsDone"
                   @onchange="() => ToggleTask(Task.Id)"
                   class="w-4 h-4 accent-indigo-500 cursor-pointer flex-shrink-0" />
        }
        <span class="flex-1 text-sm @TitleClass @(Task.IsDone ? "line-through text-gray-600" : "")">
            @Task.Title
        </span>
    </div>

    @if (Task.CompletedDate is not null)
    {
        <span class="text-sm text-gray-300">@Task.CompletedDate.TimeAgo()</span>
    }
    @if (Task.DueDate.HasValue)
    {
        <span class="text-xs font-medium px-2 py-0.5 rounded @DueDateBadgeClass">@Task.DueDate.Value.ToString("MMM d")</span>
    }
    <span class="text-xs font-medium px-2 py-0.5 rounded @PriorityBadgeClass(Task.Priority)">@Task.Priority</span>
    <span class="text-xs font-medium px-2 py-0.5 rounded bg-gray-700 text-gray-300">@Task.Effort</span>

    <div class="relative flex-shrink-0">
        <button type="button"
                @onclick="() => showContextMenu = !showContextMenu"
                @onclick:stopPropagation
                class="flex items-center justify-center w-8 h-8 text-gray-500 hover:text-gray-300 rounded transition-colors">
            ⋯
        </button>
        @if (showContextMenu)
        {
            <div class="fixed inset-0 z-10" @onclick="CloseMenu"></div>
            <div class="absolute right-0 top-full mt-1 z-20 bg-gray-800 border border-gray-700 rounded-lg shadow-lg py-1 min-w-[120px]">
                @if (isConfirmingDelete)
                {
                    <p class="px-3 py-1 text-xs text-gray-400">Delete this task?</p>
                    <button type="button"
                            @onclick="ConfirmDelete"
                            @onclick:stopPropagation
                            disabled="@isDeleting"
                            class="block w-full text-left px-3 py-2 text-sm text-red-400 hover:bg-gray-700 disabled:opacity-50 transition-colors">
                        @(isDeleting ? "Deleting…" : "Confirm")
                    </button>
                    <button type="button"
                            @onclick="() => isConfirmingDelete = false"
                            @onclick:stopPropagation
                            disabled="@isDeleting"
                            class="block w-full text-left px-3 py-2 text-sm text-gray-400 hover:bg-gray-700 disabled:opacity-50 transition-colors">
                        Cancel
                    </button>
                }
                else
                {
                    <button type="button"
                            @onclick="OpenEdit"
                            @onclick:stopPropagation
                            class="block w-full text-left px-3 py-2 text-sm text-gray-200 hover:bg-gray-700 transition-colors">
                        Edit
                    </button>
                    <button type="button"
                            @onclick="() => isConfirmingDelete = true"
                            @onclick:stopPropagation
                            class="block w-full text-left px-3 py-2 text-sm text-red-400 hover:bg-gray-700 transition-colors">
                        Delete
                    </button>
                }
            </div>
        }
    </div>
</li>

@if (showEditModal)
{
    <EditTaskModal Task="Task" OnSaved="HandleSaved" OnCancelled="() => showEditModal = false" />
}

@code {
    [Parameter]
    public TaskItemVariant Variant { get; set; } = TaskItemVariant.Today;

    [Parameter]
    public required TaskItemDto Task { get; set; }

    [Parameter]
    public EventCallback OnTaskUpdated { get; set; }

    [Parameter]
    public Guid? HighlightTaskId { get; set; }

    private bool showEditModal = false;
    private bool showContextMenu = false;
    private bool isConfirmingDelete = false;
    private bool isDeleting = false;

    private void OpenEdit()
    {
        showContextMenu = false;
        showEditModal = true;
    }

    private void CloseMenu()
    {
        showContextMenu = false;
        isConfirmingDelete = false;
    }

    private async Task HandleSaved()
    {
        showEditModal = false;
        await OnTaskUpdated.InvokeAsync();
    }

    private async Task ConfirmDelete()
    {
        isDeleting = true;
        try
        {
            var client = ClientFactory.CreateClient("WebAPI");
            await client.DeleteAsync($"api/tasks/{Task.Id}");
            await OnTaskUpdated.InvokeAsync();
        }
        finally
        {
            isDeleting = false;
            showContextMenu = false;
        }
    }

    private string ItemClass => Variant switch
    {
        TaskItemVariant.Today or TaskItemVariant.Done => "relative flex flex-wrap sm:flex-nowrap items-center gap-3 bg-gray-800 border border-gray-700 rounded-lg px-4 py-3 hover:border-gray-600 transition-colors",
        _ => "relative flex flex-wrap sm:flex-nowrap items-center gap-3 px-4 py-3 bg-gray-900 last:rounded-b-lg"
    };

    private string TitleClass => Variant switch
    {
        TaskItemVariant.Today or TaskItemVariant.Done => "text-gray-200",
        _ => "text-gray-400"
    };

    private bool ShowCheckbox => Variant == TaskItemVariant.Today || Variant == TaskItemVariant.Done;

    private async Task ToggleTask(Guid id)
    {
        var client = ClientFactory.CreateClient("WebAPI");

        await client.PatchAsync($"api/tasks/{id}/toggle", null);

        await OnTaskUpdated.InvokeAsync();
    }

    private string DueDateBadgeClass =>
        Task.DueDate.HasValue && Task.DueDate.Value < DateOnly.FromDateTime(DateTime.Now) && !Task.IsDone
            ? "bg-red-900 text-red-300"
            : "bg-blue-900 text-blue-300";

    private static string PriorityBadgeClass(Priority p) => p switch
    {
        Priority.Critical => "bg-red-900 text-red-300",
        Priority.High => "bg-orange-900 text-orange-300",
        Priority.Medium => "bg-yellow-900 text-yellow-300",
        Priority.Low => "bg-green-900 text-green-300",
        _ => "bg-gray-700 text-gray-300"
    };
}
