@page "/admin"
@attribute [Authorize(Roles = "Admin")]

@using Nudge.Shared.DTOs
@using System.Net.Http.Json

@inject IHttpClientFactory HttpClientFactory

<div class="space-y-8">
    <div>
        <h1 class="text-lg font-semibold text-gray-100 mb-4">Users</h1>
        @if (_users == null)
        {
            <p class="text-sm text-gray-500">Loading...</p>
        }
        else
        {
            <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
                @foreach (var user in _users)
                {
                    <div class="flex items-center justify-between px-4 py-3 border-b border-gray-800 last:border-0">
                        <span class="text-sm text-gray-200">@user.Email</span>
                        @if (user.IsAdmin)
                        {
                            <span class="text-xs bg-indigo-900 text-indigo-300 px-2 py-0.5 rounded-full">Admin</span>
                        }
                    </div>
                }
            </div>
        }
    </div>

    <div>
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-semibold text-gray-100">Invite Codes</h2>
            <button class="bg-indigo-600 hover:bg-indigo-500 disabled:opacity-50 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors"
                    @onclick="GenerateInvite" disabled="@_generating">
                @(_generating ? "Generating..." : "Generate Invite")
            </button>
        </div>

        @if (_invites == null)
        {
            <p class="text-sm text-gray-500">Loading...</p>
        }
        else if (_invites.Count == 0)
        {
            <p class="text-sm text-gray-500">No invite codes yet.</p>
        }
        else
        {
            <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
                @foreach (var invite in _invites)
                {
                    <div class="flex items-center justify-between px-4 py-3 border-b border-gray-800 last:border-0">
                        <code class="text-sm text-gray-300 font-mono">@invite.Code</code>
                        <div class="flex items-center gap-3">
                            <span class="text-xs text-gray-500">@invite.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")</span>
                            @if (invite.IsUsed)
                            {
                                <span class="text-xs bg-gray-800 text-gray-500 px-2 py-0.5 rounded-full">Used</span>
                            }
                            else
                            {
                                <span class="text-xs bg-green-900 text-green-400 px-2 py-0.5 rounded-full">Pending</span>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    private List<UserDto>? _users;
    private List<InviteCodeDto>? _invites;
    private bool _generating;

    protected override async Task OnInitializedAsync()
    {
        var client = HttpClientFactory.CreateClient("WebAPI");
        _users = await client.GetFromJsonAsync<List<UserDto>>("api/admin/users");
        _invites = await client.GetFromJsonAsync<List<InviteCodeDto>>("api/admin/invites");
    }

    private async Task GenerateInvite()
    {
        _generating = true;
        var client = HttpClientFactory.CreateClient("WebAPI");
        var response = await client.PostAsync("api/admin/invites", null);
        if (response.IsSuccessStatusCode)
        {
            var invite = await response.Content.ReadFromJsonAsync<InviteCodeDto>();
            _invites = [invite!, ..(_invites ?? [])];
        }
        _generating = false;
    }
}
